@page "/register"
@layout AuthLayout
@inject NavigationManager Navigation
@inject IAuthService AuthService

<div class="auth-container animate-fade-in">
    <div class="auth-card">
        <div class="auth-logo">
            <div class="auth-logo-icon">N</div>
            <div class="auth-logo-text">
                <div class="auth-logo-title">NoteHub</div>
                <div class="auth-logo-subtitle">记录你的思考</div>
            </div>
        </div>

        <div class="auth-header">
            <h1 class="auth-title">创建账号</h1>
            <p class="auth-subtitle">开始你的笔记之旅</p>
        </div>

        <EditForm Model="@model" OnValidSubmit="@HandleRegister">
            <div class="form-group">
                <label class="form-label">用户名</label>
                <InputText @bind-Value="model.UserName" class="form-input" placeholder="请输入用户名" />
            </div>

            <div class="form-group">
                <label class="form-label">邮箱</label>
                <InputText @bind-Value="model.Email" type="email" class="form-input" placeholder="请输入邮箱" />
            </div>

            <div class="form-group">
                <label class="form-label">密码</label>
                <InputText @bind-Value="model.Password" type="password" class="form-input" placeholder="请输入密码" />
            </div>

            <div class="form-group">
                <label class="form-label">确认密码</label>
                <InputText @bind-Value="model.ConfirmPassword" type="password" class="form-input" placeholder="请再次输入密码" />
            </div>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger animate-slide-up">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="10"></circle>
                        <line x1="15" y1="9" x2="9" y2="15"></line>
                        <line x1="9" y1="9" x2="15" y2="15"></line>
                    </svg>
                    @errorMessage
                </div>
            }

            <button type="submit" class="btn btn-primary btn-lg btn-block" disabled="@loading">
                @if (loading)
                {
                    <span class="loading-spinner"></span>
                }
                注册
            </button>
        </EditForm>

        <div class="auth-footer">
            <span>已有账号？</span>
            <a href="/login" class="auth-link">
                立即登录
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="5" y1="12" x2="19" y2="12"></line>
                    <polyline points="12 5 19 12 12 19"></polyline>
                </svg>
            </a>
        </div>
    </div>
</div>

@code {
    private RegisterModel model = new();
    private bool loading;
    private string? errorMessage;

    private async Task HandleRegister()
    {
        if (model.Password != model.ConfirmPassword)
        {
            errorMessage = "两次输入的密码不一致";
            return;
        }

        errorMessage = null;
        loading = true;

        var result = await AuthService.RegisterAsync(model.UserName, model.Email, model.Password);
        if (result)
        {
            Navigation.NavigateTo("/login", forceLoad: true);
        }
        else
        {
            errorMessage = "用户名已存在";
        }

        loading = false;
    }

    private class RegisterModel
    {
        public string UserName { get; set; } = string.Empty;
        public string Email { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
        public string ConfirmPassword { get; set; } = string.Empty;
    }
}
