@page "/search"
@inject INoteService NoteService
@inject ICategoryService CategoryService
@inject NavigationManager Navigation
@implements IDisposable


<div class="page-header animate-slide-up">
    <h1 class="page-title">搜索结果</h1>
</div>

<div class="search-container animate-slide-up animate-delay-1">
    <div class="search-box">
        <svg class="search-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
             stroke-width="2">
            <circle cx="11" cy="11" r="8"></circle>
            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
        </svg>
        <input type="text" class="search-input" placeholder="输入搜索关键词" @bind="searchQuery"
               @onkeydown="@(e => { if (e.Key == "Enter") HandleSearch(); })" />
        <button class="btn btn-primary search-btn" @onclick="HandleSearch">搜索</button>
    </div>
</div>

@if (!string.IsNullOrEmpty(query))
{
    <p class="search-results-count animate-fade-in">
        搜索 "@query"，@notes.Count 结果
    </p>
}

@if (notes.Any())
{
    <div class="grid grid-2 animate-slide-up animate-delay-2">
        @foreach (var note in notes)
        {
            <NoteCard Note="note" CategoryName="@GetCategoryName(note.CategoryId)" />
        }
    </div>
}
else if (!string.IsNullOrEmpty(query))
{
    <div class="empty-state animate-scale-in">
        <div class="empty-state-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="11" cy="11" r="8"></circle>
                <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
            </svg>
        </div>
        <p class="empty-state-title">没有找到匹配的笔记</p>
        <p class="empty-state-text">尝试其他关键词</p>
    </div>
}

@code {
    private string query = string.Empty;
    private string searchQuery = string.Empty;
    private List<Note> notes = new();
    private Dictionary<int, string> categoryNames = new();

    protected override async Task OnInitializedAsync()
    {
        Navigation.LocationChanged += OnLocationChanged;
        await LoadFromUri();
    }

    private async void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        await LoadFromUri();
    }

    private async Task LoadFromUri()
    {
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        var queryParams = QueryHelpers.ParseQuery(uri.Query);
        query = queryParams.TryGetValue("q", out var qValue) ? qValue.ToString() : string.Empty;
        searchQuery = query;

        if (!string.IsNullOrEmpty(query))
        {
            await SearchAsync();
        }
        else
        {
            notes = new List<Note>();
        }
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= OnLocationChanged;
    }

    private async Task SearchAsync()
    {
        notes = (await NoteService.SearchAsync(query)).ToList();

        var categories = await CategoryService.GetAllAsync();
        foreach (var category in categories)
        {
            categoryNames[category.Id] = category.Name;
        }
    }

    private void HandleSearch()
    {
        if (!string.IsNullOrWhiteSpace(searchQuery))
        {
            Navigation.NavigateTo($"/search?q={Uri.EscapeDataString(searchQuery)}");
        }
    }

    private string? GetCategoryName(int? categoryId)
    {
        if (!categoryId.HasValue) return null;
        return categoryNames.GetValueOrDefault(categoryId.Value);
    }
}
