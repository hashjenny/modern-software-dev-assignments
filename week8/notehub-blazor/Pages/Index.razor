@page "/"
@inject INoteService NoteService
@inject ICategoryService CategoryService

<div class="hero animate-slide-up">
    <div class="hero-badge">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
        </svg>
        <span>你的个人笔记中心</span>
    </div>
    <h1 class="hero-title">NoteHub</h1>
    <p class="hero-subtitle">记录思考，整理知识，让灵感有序流淌</p>
    <div class="hero-actions">
        <a href="/notes/new" class="btn btn-primary btn-lg">
            <span>开始记录</span>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="5" y1="12" x2="19" y2="12"></line>
                <polyline points="12 5 19 12 12 19"></polyline>
            </svg>
        </a>
    </div>
</div>

<section class="section animate-slide-up animate-delay-1">
    <div class="section-header">
        <div class="section-title">
            <svg class="section-title-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10"></circle>
                <polyline points="12 6 12 12 16 14"></polyline>
            </svg>
            <h2>最近笔记</h2>
        </div>
        @if (recentNotes.Any())
        {
            <a href="/notes" class="section-link">
                查看全部
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="9 18 15 12 9 6"></polyline>
                </svg>
            </a>
        }
    </div>

    @if (recentNotes.Any())
    {
        <div class="grid grid-4">
            @foreach (var note in recentNotes)
            {
                <NoteCard Note="note" CategoryName="@GetCategoryName(note.CategoryId)" />
            }
        </div>
    }
    else
    {
        <div class="empty-state">
            <div class="empty-state-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                    <polyline points="14 2 14 8 20 8"></polyline>
                    <line x1="12" y1="18" x2="12" y2="12"></line>
                    <line x1="9" y1="15" x2="15" y2="15"></line>
                </svg>
            </div>
            <p class="empty-state-title">还没有笔记</p>
            <p class="empty-state-text">开始创建你的第一篇笔记吧</p>
            <a href="/notes/new" class="btn btn-primary">创建笔记</a>
        </div>
    }
</section>

<section class="section animate-slide-up animate-delay-2">
    <div class="section-header">
        <div class="section-title">
            <svg class="section-title-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"></path>
            </svg>
            <h2>分类</h2>
        </div>
        @if (recentCategories.Any())
        {
            <a href="/categories" class="section-link">
                查看全部
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polyline points="9 18 15 12 9 6"></polyline>
                </svg>
            </a>
        }
    </div>

    @if (recentCategories.Any())
    {
        <div class="grid grid-4">
            @foreach (var category in recentCategories)
            {
                <CategoryCard Category="category" NoteCount="@GetNoteCount(category.Id)" />
            }
        </div>
    }
    else
    {
        <div class="empty-state">
            <div class="empty-state-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"></path>
                    <line x1="12" y1="11" x2="12" y2="17"></line>
                    <line x1="9" y1="14" x2="15" y2="14"></line>
                </svg>
            </div>
            <p class="empty-state-title">还没有分类</p>
            <p class="empty-state-text">创建分类来整理你的笔记</p>
            <a href="/categories/new" class="btn btn-primary">创建分类</a>
        </div>
    }
</section>

@code {
    private List<Note> recentNotes = new();
    private List<Category> recentCategories = new();
    private Dictionary<int, string> categoryNames = new();

    protected override async Task OnInitializedAsync()
    {
        recentNotes = (await NoteService.GetAllAsync())
            .OrderByDescending(n => n.CreatedAt)
            .Take(4)
            .ToList();

        recentCategories = (await CategoryService.GetAllAsync())
            .ToList();

        foreach (var category in recentCategories)
        {
            categoryNames[category.Id] = category.Name;
        }
    }

    private string? GetCategoryName(int? categoryId)
    {
        if (!categoryId.HasValue) return null;
        return categoryNames.GetValueOrDefault(categoryId.Value);
    }

    private int GetNoteCount(int categoryId)
    {
        return recentNotes.Count(n => n.CategoryId == categoryId);
    }
}
