@page "/notes/new"
@page "/notes/{Id:int}/edit"
@inject INoteService NoteService
@inject ICategoryService CategoryService
@inject NavigationManager Navigation

<div class="card animate-slide-up">
    <div class="card-header">
        <h1 class="detail-title">@(Id == 0 ? "新建笔记" : "编辑笔记")</h1>
    </div>
    <div class="card-body">
        <EditForm Model="@note" OnValidSubmit="@HandleSubmit">
            <div class="form-group">
                <label class="form-label">标题</label>
                <InputText @bind-Value="note.Title" class="form-input" placeholder="请输入标题" />
                <ValidationMessage For="@(() => note.Title)" />
            </div>

            <div class="form-group">
                <label class="form-label">分类</label>
                <InputSelect @bind-Value="note.CategoryId" class="form-select">
                    <option value="">无</option>
                    @foreach (var category in categories)
                    {
                        <option value="@category.Id">@category.Name</option>
                    }
                </InputSelect>
            </div>

            <div class="form-group">
                <label class="form-label">内容</label>
                <InputTextArea @bind-Value="note.Content" class="form-textarea" placeholder="请输入内容" />
                <ValidationMessage For="@(() => note.Content)" />
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <polyline points="20 6 9 17 4 12"></polyline>
                    </svg>
                    保存
                </button>
                <a href="/notes" class="btn btn-secondary">取消</a>
            </div>
        </EditForm>
    </div>
</div>

@code {
    [Parameter]
    public int Id { get; set; }

    private Note note = new();
    private List<Category> categories = new();
    private bool isNew => Id == 0;

    protected override async Task OnInitializedAsync()
    {
        categories = (await CategoryService.GetAllAsync()).ToList();

        if (!isNew)
        {
            note = await NoteService.GetByIdAsync(Id) ?? new Note();
        }
    }

    private async Task HandleSubmit()
    {
        if (isNew)
        {
            await NoteService.CreateAsync(note);
        }
        else
        {
            await NoteService.UpdateAsync(note);
        }

        Navigation.NavigateTo("/notes");
    }
}
