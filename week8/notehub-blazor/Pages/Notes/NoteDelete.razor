@page "/notes/{Id:int}/delete"
@inject INoteService NoteService
@inject IAuthService AuthService
@inject NavigationManager Navigation

@if (note != null)
{
    <div class="card animate-slide-up">
        <div class="card-header">
            <h1 class="detail-title">确认删除</h1>
        </div>
        <div class="card-body">
            <p class="text-secondary mb-lg">
                确定要删除笔记 "<strong>@note.Title</strong>" 吗？此操作不可撤销。
            </p>
            <div class="form-actions">
                <button class="btn btn-danger" @onclick="HandleDelete">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <polyline points="3 6 5 6 21 6"></polyline>
                        <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                    </svg>
                    删除
                </button>
                <a href="/notes/@Id" class="btn btn-secondary">取消</a>
            </div>
        </div>
    </div>
}
else
{
    <div class="empty-state animate-scale-in">
        <div class="empty-state-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10"></circle>
                <line x1="15" y1="9" x2="9" y2="15"></line>
                <line x1="9" y1="9" x2="15" y2="15"></line>
            </svg>
        </div>
        <p class="empty-state-title">笔记不存在</p>
        <p class="empty-state-text">该笔记可能已被删除</p>
        <a href="/notes" class="btn btn-primary">返回列表</a>
    </div>
}

@code {
    [Parameter]
    public int Id { get; set; }

    private Note? note;

    protected override async Task OnInitializedAsync()
    {
        var userId = await AuthService.GetUserIdAsync();
        if (string.IsNullOrEmpty(userId))
        {
            Navigation.NavigateTo("/login");
            return;
        }

        note = await NoteService.GetByIdAsync(Id, userId);
    }

    private async Task HandleDelete()
    {
        var userId = await AuthService.GetUserIdAsync();
        if (string.IsNullOrEmpty(userId)) return;

        await NoteService.DeleteAsync(Id, userId);
        Navigation.NavigateTo("/notes");
    }
}
