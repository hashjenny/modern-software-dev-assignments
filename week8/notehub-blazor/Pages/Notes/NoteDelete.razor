@page "/notes/{Id:int}/delete"
@inject INoteService NoteService
@inject IAuthService AuthService
@inject NavigationManager Navigation
@using notehub_blazor.Components


@if (note != null)
{
    <MudAlert Severity="Severity.Warning" Class="mb-4">
        <MudText Typo="Typo.h6">确认删除</MudText>
        <MudText>确定要删除笔记 "<strong>@note.Title</strong>" 吗？此操作不可撤销。</MudText>
    </MudAlert>

    <MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="HandleDelete" Class="mr-2">删除</MudButton>
    <MudButton Variant="Variant.Outlined" OnClick="@(() => Navigation.NavigateTo($"/notes/{Id}"))">取消</MudButton>
}
else
{
    <MudAlert Severity="Severity.Error">笔记不存在</MudAlert>
    <MudButton Variant="Variant.Outlined" Href="/notes" Class="mt-2">返回列表</MudButton>
}

@code {
    [Parameter]
    public int Id { get; set; }

    private Note? note;

    protected override async Task OnInitializedAsync()
    {
        var userId = await AuthService.GetUserIdAsync();
        if (string.IsNullOrEmpty(userId))
        {
            Navigation.NavigateTo("/login");
            return;
        }

        note = await NoteService.GetByIdAsync(Id, userId);
    }

    private async Task HandleDelete()
    {
        var userId = await AuthService.GetUserIdAsync();
        if (string.IsNullOrEmpty(userId)) return;

        await NoteService.DeleteAsync(Id, userId);
        Navigation.NavigateTo("/notes");
    }


}
