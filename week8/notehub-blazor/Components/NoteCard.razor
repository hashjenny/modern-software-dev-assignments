@using notehub_blazor.Models

<MudCard Class="nh-note-card animate-in" Elevation="0">
    <div class="nh-note-card-accent"></div>
    <MudCardHeader Class="nh-note-card-header">
        <CardHeaderContent>
            <div class="nh-note-title-row">
                <MudText Typo="Typo.h6" Class="nh-note-title">@Note.Title</MudText>
                @if (!string.IsNullOrEmpty(CategoryName))
                {
                    <MudChip T="string" Size="Size.Small" Class="nh-note-category">@CategoryName</MudChip>
                }
            </div>
            <div class="nh-note-meta">
                <span class="material-icons">schedule</span>
                <span>@Note.CreatedAt.ToString("yyyy-MM-dd")</span>
            </div>
        </CardHeaderContent>
    </MudCardHeader>
    <MudCardContent Class="nh-note-card-content">
        <MudText Typo="Typo.body2" Class="nh-note-excerpt">
            @if (!string.IsNullOrEmpty(Note.Content) && Note.Content.Length > 120)
            {
                @Note.Content.Substring(0, 120)
                <span class="nh-note-ellipsis">...</span>
            }
            else
            {
                @Note.Content
            }
        </MudText>
    </MudCardContent>
    <MudCardActions Class="nh-note-card-actions">
        <MudButton Variant="Variant.Text" Color="Color.Default" Size="Size.Small" Href="@($"/notes/{Note.Id}")" Class="nh-note-action-btn">
            <span class="material-icons">visibility</span>
            <span>查看</span>
        </MudButton>
        <MudButton Variant="Variant.Text" Color="Color.Default" Size="Size.Small" Href="@($"/notes/{Note.Id}/edit")" Class="nh-note-action-btn">
            <span class="material-icons">edit</span>
            <span>编辑</span>
        </MudButton>
    </MudCardActions>
</MudCard>

<style>
    .nh-note-card {
        background: var(--color-bg-paper);
        border: 1px solid var(--color-border);
        border-radius: 4px;
        transition: all 200ms ease;
        position: relative;
        overflow: hidden;
        height: 100%;
        display: flex;
        flex-direction: column;
    }

    .nh-note-card:hover {
        border-color: var(--color-border-strong);
        box-shadow: 0 8px 24px var(--color-shadow-strong);
        transform: translateY(-4px);
    }

    .nh-note-card:hover .nh-note-card-accent {
        opacity: 1;
    }

    .nh-note-card-accent {
        position: absolute;
        top: 0;
        left: 0;
        width: 4px;
        height: 100%;
        background: linear-gradient(180deg, var(--color-accent-primary), var(--color-accent-secondary));
        opacity: 0;
        transition: opacity 200ms ease;
    }

    .nh-note-card-header {
        padding: var(--space-lg) var(--space-lg) var(--space-sm) !important;
    }

    .nh-note-title-row {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: var(--space-md);
        margin-bottom: var(--space-xs);
    }

    .nh-note-title {
        font-family: 'Syne', sans-serif !important;
        font-weight: 700 !important;
        font-size: 1.1rem !important;
        color: var(--color-text-primary) !important;
        line-height: 1.3;
    }

    .nh-note-category {
        background: rgba(196, 93, 53, 0.08) !important;
        color: var(--color-accent-primary) !important;
        font-family: 'Syne', sans-serif !important;
        font-size: 0.65rem !important;
        font-weight: 600 !important;
        letter-spacing: 0.05em !important;
        text-transform: uppercase !important;
        flex-shrink: 0;
    }

    .nh-note-meta {
        display: flex;
        align-items: center;
        gap: 4px;
        color: var(--color-text-muted);
        font-size: 0.75rem;
    }

    .nh-note-meta .material-icons {
        font-size: 0.85rem;
        color: var(--color-text-muted);
    }

    .nh-note-card-content {
        padding: 0 var(--space-lg) var(--space-lg) !important;
        flex: 1;
    }

    .nh-note-excerpt {
        font-family: 'Source Serif 4', serif;
        color: var(--color-text-secondary);
        font-size: 0.9rem;
        line-height: 1.6;
    }

    .nh-note-ellipsis {
        color: var(--color-text-muted);
    }

    .nh-note-card-actions {
        padding: var(--space-sm) var(--space-lg) var(--space-md) !important;
        border-top: 1px solid var(--color-border);
        display: flex;
        gap: var(--space-sm);
    }

    .nh-note-action-btn {
        font-family: 'Syne', sans-serif !important;
        font-size: 0.75rem !important;
        font-weight: 500 !important;
        color: var(--color-text-muted) !important;
        text-transform: uppercase !important;
        letter-spacing: 0.03em !important;
        display: flex !important;
        align-items: center !important;
        gap: 4px !important;
        padding: 6px 12px !important;
        border-radius: 4px !important;
        transition: all 150ms ease !important;
    }

    .nh-note-action-btn:hover {
        background: var(--color-bg-secondary) !important;
        color: var(--color-accent-primary) !important;
    }

    .nh-note-action-btn .material-icons {
        font-size: 0.9rem !important;
    }

    /* Animation */
    .animate-in {
        opacity: 0;
        animation: fadeSlideUp 0.5s ease forwards;
    }

    @@keyframes fadeSlideUp {
        from { opacity: 0; transform: translateY(15px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>

@code {
    [Parameter]
    public Note Note { get; set; } = null!;

    [Parameter]
    public string? CategoryName { get; set; }
}
