@using notehub_blazor.Models

<div class="category-card animate-slide-up">
    <div class="category-card-icon">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"></path>
        </svg>
    </div>
    <div class="category-card-name">
        <a href="/categories/@Category.Id">@Category.Name</a>
    </div>
    <div class="note-card-meta">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
            <line x1="16" y1="2" x2="16" y2="6"></line>
            <line x1="8" y1="2" x2="8" y2="6"></line>
            <line x1="3" y1="10" x2="21" y2="10"></line>
        </svg>
        <span>@Category.CreatedAt.ToString("yyyy-MM-dd")</span>
    </div>
    @if (NoteCount.HasValue && NoteCount > 0)
    {
        <div class="category-card-count">
            <span>@NoteCount</span> 篇笔记
        </div>
    }
    else
    {
        <div class="category-card-count text-muted" style="font-style: italic;">暂无笔记</div>
    }
    <div class="category-card-actions">
        <a href="/categories/@Category.Id" class="btn btn-ghost btn-sm">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                <circle cx="12" cy="12" r="3"></circle>
            </svg>
            查看
        </a>
        <a href="/categories/@Category.Id/edit" class="btn btn-ghost btn-sm">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
                <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
            </svg>
            编辑
        </a>
    </div>
</div>

@code {
    [Parameter]
    public Category Category { get; set; } = null!;

    [Parameter]
    public int? NoteCount { get; set; }
}
