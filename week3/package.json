{
  "name": "weather-mcp-server",
  "version": "1.0.0",
  "type": "module",
  "description": "MCP server for weather and clothing advice",
  "main": "build/index.js",
  "scripts": {
    "build": "tsc",
    "cli": "node build/cli.js",
    "mcp": "node build/index.js",
    "dev": "tsc && node build/index.js",
    "start:http": "node build/http-server.js",
    "dev:http": "tsc && node build/http-server.js",
    "verify:stdio": "node build/verify-client.js --transport stdio",
    "verify:http": "node build/verify-client.js --transport http --http-url http://127.0.0.1:3000",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@types/express": "^5.0.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jose": "^6.1.3",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.2"
  }
}
