WEATHER_HOST=https://xxxxxx.re.qweatherapi.com
WEATHER_KEY=your_qweather_api_key
LOC=location_code

# HTTP/API Key 认证（可选）
MCP_API_KEY=your_mcp_api_key

# HTTP/OAuth2 Bearer 认证（可选）
OAUTH_JWT_SECRET=your_hs256_secret
OAUTH_AUDIENCE=weather-mcp
# OAUTH_ISSUER=https://your-auth-server.example.com

# verify-client（可选，仅当你启用OAuth2时使用）
# OAUTH_BEARER_TOKEN=your_bearer_jwt
